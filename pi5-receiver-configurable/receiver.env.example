# Copy this file to receiver.env and adjust to your Pi 5.

# Host paths
BASE_DIR=/opt/pi-receiver
SHARED_DIR=/opt/pi-receiver/shared
HOST_DIR=/opt/pi-receiver/host
STATE_FILE=/opt/pi-receiver/shared/state.json
RELOAD_TOKEN_FILE=/opt/pi-receiver/shared/reload.token
HOST_BLANK_URL=file:///opt/pi-receiver/host/blank.html

# API / Docker
API_PORT=18091
CONTAINER_PORT=8091

# Kiosk / desktop session
ENABLE_KIOSK=1
KIOSK_USER=maxi
DISPLAY_NUM=:0
XAUTHORITY_PATH=/home/maxi/.Xauthority
CHROMIUM_BIN=auto
KIOSK_POLL_SECONDS=2

# Default URL when nothing else is set
DEFAULT_URL=file:///opt/pi-receiver/host/blank.html
